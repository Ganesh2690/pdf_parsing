.DS_Store
Thumbs.db
desktop.ini

# Raw downloaded PDFs and datasets (binary data, not source code)
data/raw/
data/text_exports/

# Generated parse outputs (reproducible from source + data)
data/parsed/

# Keep catalog (small, useful for repo readers)
!data/catalog/
!data/catalog/pdf_catalog.jsonl

# Logs (keep sample/example logs, exclude live run logs)
logs/*.jsonl
!logs/.gitkeep

# Generated HTML reports
reports/
artifacts/reports/
artifacts/run_manifest.json
artifacts/environment_snapshot.json

# Temp / scratch files
*.log
extract_*_console.log
extract_ocr*.log
extract_ocrmypdf*.log
download_run.log

